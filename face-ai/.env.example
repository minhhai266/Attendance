APP_NAME=Face Lab System
SECRET_KEY=change-this-to-a-long-random-secret-key
DATABASE_PATH=data/face_lab.db
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_DET_SIZE=416
FACE_THRESHOLD=0.55
CHECK_COOLDOWN_SECONDS=30
FRAME_SKIP=2
CHECK_IN_CAMERA_DEVICE_ID=
CHECK_OUT_CAMERA_DEVICE_ID=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
LOGIN_MAX_FAILED_ATTEMPTS=10
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900
SESSION_MAX_AGE_SECONDS=28800
HTTPS_ENABLED=false
TRUSTED_HOSTS=127.0.0.1,localhost
PUBLIC_DOCS_ENABLED=false
HEALTH_DETAILS_ENABLED=false
PASSWORD_PBKDF2_ITERATIONS=600000
WEBSOCKET_ALLOWED_ORIGINS=http://127.0.0.1:8002,http://localhost:8002
WEBSOCKET_MAX_MESSAGE_BYTES=524288
WEBSOCKET_MAX_IMAGE_BYTES=393216
WEBSOCKET_MAX_IMAGE_PIXELS=1000000
WORK_START_TIME=08:00
WORK_END_TIME=17:00
LATE_GRACE_MINUTES=5
EARLY_LEAVE_GRACE_MINUTES=10

# Anti-spoofing / liveness detection
# Default model expects RGB 128x128 input and outputs [real, spoof] logits.
LIVENESS_ENABLED=true
ANTI_SPOOF_MODEL_PATH=models/anti_spoofing/best_model_quantized.onnx
LIVENESS_THRESHOLD=0.5
LIVENESS_REAL_CLASS_INDEX=0
LIVENESS_INPUT_SIZE=128
LIVENESS_CROP_SCALE=1.5
LIVENESS_MIN_FACE_SIZE=80
LIVENESS_MIN_BRIGHTNESS=35
LIVENESS_MIN_BLUR=18
LIVENESS_EDGE_MARGIN=5
